generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  name      String?
  email     String    @unique
  password  String
  role      UserRole  @default(MANAGER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  properties Property[]
}

enum UserRole {
  DIRECTOR
  MANAGER
}

model Property {
  id          String     @id @default(uuid())
  name        String
  address     String
  city        String
  zipCode     String
  description String?
  type        PropertyType
  status      PropertyStatus @default(ACTIVE)
  imageUrl    String[]
  ownerId     String?
  owner       User?      @relation(fields: [ownerId], references: [id])
  units       Unit[]
  meters      Meter[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  crmRecords  CrmRecord[]
}

model Unit {
  id              String      @id @default(uuid())
  propertyId      String
  property        Property    @relation(fields: [propertyId], references: [id])
  number          String      // e.g. "EG links", "01"
  floor           String?
  area            Decimal     @db.Decimal(10, 2)
  rooms           Decimal?    @db.Decimal(3, 1)
  baseRent        Decimal     @db.Decimal(10, 2)
  utilityPrepay   Decimal     @db.Decimal(10, 2)
  status          UnitStatus  @default(VACANT)
  tenants         Tenant[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum UnitStatus {
  VACANT
  RENTED
  RENOVATION
  RESERVED
}

model Tenant {
  id            String    @id @default(uuid())
  unitId        String?
  unit          Unit?     @relation(fields: [unitId], references: [id])
  firstName     String
  lastName      String
  email         String?
  phone         String?
  moveInDate    DateTime?
  moveOutDate   DateTime?
  deposit       Decimal?  @db.Decimal(10, 2)
  iban          String?
  payments      Payment[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Meter {
  id              String    @id @default(uuid())
  propertyId      String
  property        Property  @relation(fields: [propertyId], references: [id])
  type            MeterType
  serialNumber    String    @unique
  unitId          String?   // Can be for entire house or specific unit
  readings        MeterReading[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum MeterType {
  WATER_COLD
  WATER_HOT
  HEATING
  ELECTRICITY
  GAS
}

model MeterReading {
  id        String    @id @default(uuid())
  meterId   String
  meter     Meter     @relation(fields: [meterId], references: [id])
  date      DateTime
  value     Decimal   @db.Decimal(12, 3)
  createdAt DateTime  @default(now())
}

model Payment {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  amount      Decimal   @db.Decimal(10, 2)
  date        DateTime
  type        PaymentType @default(RENT)
  status      PaymentStatus @default(COMPLETED)
  reference   String?
  createdAt   DateTime  @default(now())
}

enum PaymentType {
  RENT
  UTILITIES
  DEPOSIT
  REPAIR
  OTHER
}

enum PaymentStatus {
  COMPLETED
  PENDING
  FAILED
  REFUNDED
}

enum PropertyType {
  OFFICE_BUILDING
  FACTORY_YARD
  COMMERCIAL_YARD
  INDUSTRIAL_LAND
  NURSING_HOME
  OTHER
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  SOLD
}

model CrmRecord {
  id          String    @id @default(uuid())
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id])
  recordType  CrmRecordType
  description String
  date        DateTime  @default(now())
  assignedTo  String? 
  status      CrmRecordStatus @default(OPEN)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum CrmRecordType {
  SERVICE_REQUEST
  TENANT_INTERACTION
  MAINTENANCE_LOG
  INSPECTION
  OTHER
}

enum CrmRecordStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  PENDING
}
